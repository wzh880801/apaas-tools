{
  "manifest_version": 3,
  "name": "aPaaS Tools",
  "version": "1.0.0",
  "description": "A Chrome extension with side panel support.",
  "permissions": [
    "sidePanel",
    "activeTab",
    "tabs",
    "storage",
    "cookies",
    "webRequest"
  ],
  "host_permissions": [
    "*://*.aedev.feishuapp.cn/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.aedev.feishuapp.cn/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "action": {
    "default_title": "打开 aPaaS Tools 侧边栏",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel/index.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
